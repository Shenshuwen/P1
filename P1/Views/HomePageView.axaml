<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="P1.Views.HomePageView"
              xmlns:vm="using:P1.ViewModels" 
             x:DataType="vm:HomePageViewModel">

    <Design.DataContext>
        <vm:HomePageViewModel/>
    </Design.DataContext>



    <Grid Background="#1A1032" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="实时数据看板" 
                       Foreground="White" 
                       FontSize="28" 
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding Time}" 
                       Foreground="LightGray" 
                       FontSize="14"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 数据卡片区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel HorizontalAlignment="Center" >
                
                <!-- 体积流量卡片 -->
                <Border Background="#2A2A2A" 
                        CornerRadius="12" 
                        Width="250" 
                        Height="150"
                        BorderBrush="#404040" 
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">

                        <TextBlock Text="风速" 
                                   Foreground="LightBlue" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Wind}" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="m/s" 
                                   Foreground="LightGray" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <Border Background="Green" 
                                CornerRadius="10" 
                                Padding="8,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="正常" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 质量流量卡片 -->
                <Border Background="#2A2A2A" 
                        CornerRadius="12" 
                        Width="250" 
                        Height="150"
                        BorderBrush="#404040" 
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="压力" 
                                   Foreground="LightGreen" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stress}" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="pa" 
                                   Foreground="LightGray" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <Border Background="Green" 
                                CornerRadius="10" 
                                Padding="8,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="正常" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 供水温度卡片 -->
                <Border Background="#2A2A2A" 
                        CornerRadius="12" 
                        Width="250" 
                        Height="150"
                        BorderBrush="#404040" 
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="温度" 
                                   Foreground="Orange" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
						<TextBlock Text="{Binding Tem}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="°C" 
                                   Foreground="LightGray" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <Border Background="Orange" 
                                CornerRadius="10" 
                                Padding="8,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="偏高" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 回水温度卡片 -->
                <Border Background="#2A2A2A" 
                        CornerRadius="12" 
                        Width="250" 
                        Height="150"
                        BorderBrush="#404040" 
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="湿度" 
                                   Foreground="LightCoral" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
						<TextBlock Text="{Binding Wep}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="%RH" 
                                   Foreground="LightGray" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <Border Background="Green" 
                                CornerRadius="10" 
                                Padding="8,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="正常" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 压力卡片 -->
                <Border Background="#2A2A2A" 
                        CornerRadius="12" 
                        Width="250" 
                        Height="150"
                        BorderBrush="#404040" 
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="压力" 
                                   Foreground="Violet" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="0.85" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MPa" 
                                   Foreground="LightGray" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <Border Background="Green" 
                                CornerRadius="10" 
                                Padding="8,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="正常" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 瞬时热量卡片 -->
                <Border Background="#2A2A2A" 
                        CornerRadius="12" 
                        Width="250" 
                        Height="150"
                        BorderBrush="#404040" 
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="瞬时热量" 
                                   Foreground="Gold" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="12.8" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MW" 
                                   Foreground="LightGray" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <Border Background="Green" 
                                CornerRadius="10" 
                                Padding="8,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="正常" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 累计热量卡片 -->
                <Border Background="#2A2A2A" 
                        CornerRadius="12" 
                        Width="250" 
                        Height="150"
                        BorderBrush="#404040" 
                        BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="累计热量" 
                                   Foreground="Cyan" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="12560.8" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="GJ" 
                                   Foreground="LightGray" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <Border Background="Blue" 
                                CornerRadius="10" 
                                Padding="8,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="运行中" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </ScrollViewer>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" 
                Background="#2A2A2A" 
                BorderBrush="#404040" 
                BorderThickness="1,1,0,0"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="12" Height="12" Fill="Green"/>
                        <TextBlock Text="系统运行正常" Foreground="White" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="12" Height="12" Fill="Green"/>
                        <TextBlock Text="数据采集正常" Foreground="White" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="刷新频率: 1秒" Foreground="LightGray" FontSize="14"/>
                    <TextBlock Text="数据源: PLC-01" Foreground="LightGray" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
