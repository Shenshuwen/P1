<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:P1.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="600"
        x:Class="P1.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1024"
        Height="600"
        Title="P1"
		xmlns:view="using:P1.Views">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

 <Grid Background="{DynamicResource ResourceKey=PrimaryBackground}" ColumnDefinitions="220,*">

	 <ContentControl Grid.Column="1" Background="#0F0B23" Content="{Binding CurrentPage}"/>

	 
     <Border Grid.Column="0" Padding="20" Background="{ DynamicResource PrimaryBackgroundGradient}" >
         <Grid RowDefinitions="*,auto">
			 <StackPanel Spacing="12">
				 <Image PointerPressed="Image_PointerPressed" Source="avares://P1/Assets/Image/school2.ico" HorizontalAlignment="Left"  Width="50" Height="50"/>
                <TextBlock Text="CJLU" Foreground="white" FontSize="20" />
                <TextBlock Text="智慧实验室平台" Foreground="white" FontSize="20" />

				 <Button HorizontalAlignment="Stretch" Classes.active="{Binding HomePageIsActive}" Command="{Binding GoToHome}">
					 <StackPanel Orientation="Horizontal" Spacing="8">
						 <!-- 主页图标 -->
						 <Viewbox Width="16" Height="16" VerticalAlignment="Center">
							 <Path Data="M12 2.1L1 12H4V22H10V16H14V22H20V12H23L12 2.1Z"
								   Fill="White"/>
						 </Viewbox>
						 <TextBlock Text="主页" IsVisible="{Binding SideMenuExpanded}"  VerticalAlignment="Center"/>
					 </StackPanel>
				 </Button>

				 <Button HorizontalAlignment="Stretch" Classes.active="{Binding ProcessPageIsActive}" Command="{Binding GoToProcess}">
					 <StackPanel Orientation="Horizontal" Spacing="8">
						 <!-- 进程图标 -->
						 <Viewbox Width="16" Height="16" VerticalAlignment="Center">
							 <Path Data="M2 12A10 10 0 1 0 12 2A10 10 0 0 0 2 12M12 8A4 4 0 1 1 8 12A4 4 0 0 1 12 8Z"
								   Fill="White"/>
						 </Viewbox>
						 <TextBlock Text="进程" IsVisible="{Binding SideMenuExpanded}" VerticalAlignment="Center"/>
					 </StackPanel>
				 </Button>

				 <Button HorizontalAlignment="Stretch">
					 <StackPanel Orientation="Horizontal" Spacing="8">
						 <!-- 操作图标 -->
						 <Viewbox Width="16" Height="16" VerticalAlignment="Center">
							 <Path Data="M8 5V11L12 8L8 5M12 2A10 10 0 1 0 22 12A10 10 0 0 0 12 2Z"
								   Fill="White"/>
						 </Viewbox>
						 <TextBlock Text="操作" IsVisible="{Binding SideMenuExpanded}" VerticalAlignment="Center"/>
					 </StackPanel>
				 </Button>

				 <Button HorizontalAlignment="Stretch">
					 <StackPanel Orientation="Horizontal" Spacing="8">
						 <!-- 命令图标 -->
						 <Viewbox Width="16" Height="16" VerticalAlignment="Center">
							 <Path Data="M4 6H20V8H4V6M4 10H20V12H4V10M4 14H16V16H4V14Z"
								   Fill="White"/>
						 </Viewbox>
						 <TextBlock Text="命令" IsVisible="{Binding SideMenuExpanded}" VerticalAlignment="Center"/>
					 </StackPanel>
				 </Button>

				 <Button HorizontalAlignment="Stretch" Classes.active="{Binding HistoryPageIsActive}" Command="{Binding GoToHistory}">
					 <StackPanel Orientation="Horizontal" Spacing="8">
						 <!-- 历史图标 -->
						 <Viewbox Width="16" Height="16" VerticalAlignment="Center">
							 <Path Data="M12 2A10 10 0 0 0 2 12A10 10 0 0 0 12 22A10 10 0 0 0 12 2M12 6V12L16 14L12 6Z"
								   Fill="White"/>
						 </Viewbox>
						 <TextBlock Text="历史" IsVisible="{Binding SideMenuExpanded}" VerticalAlignment="Center"/>
					 </StackPanel>
				 </Button>
             </StackPanel>
			 <!--齿轮图标 -->
			 <Button Grid.Row="1" Command="{Binding GoToSetting}">
				 <Viewbox Width="20" Height="20">
					 <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.22,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
						   Fill="White"/>
				 </Viewbox>
			 </Button>
         </Grid>
     </Border>
 </Grid>

</Window>
