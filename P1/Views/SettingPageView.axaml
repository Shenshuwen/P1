<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600"
             x:Class="P1.Views.SettingPageView"
             xmlns:vm="using:P1.ViewModels" 
             x:DataType="vm:SettingPageViewModel">

    <Design.DataContext>
        <vm:SettingPageViewModel/>
    </Design.DataContext>

    <Grid Background="#1A1A1A">
        <Border Background="#252525" CornerRadius="10" Margin="20" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="连接参数（模块已预先串口配置为 STA + TCP Server）"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <Border Background="#1F2937" CornerRadius="8" Padding="8">
                    <TextBlock Text="{Binding SetupGuide}" Foreground="#BFDBFE" TextWrapping="Wrap"/>
                </Border>

                <Grid ColumnDefinitions="Auto,260" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="模块 IP" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IpAddress}" Watermark="192.168.3.100"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="模块端口" Foreground="White" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="65535" Value="{Binding Port}"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="测试连接" Command="{Binding IpsettingCommand}" Background="#60A5FA" Foreground="Black"/>
                    <Button Content="保存参数" Command="{Binding SaveSettingCommand}" Background="#86EFAC" Foreground="Black"/>
                </StackPanel>

                <TextBlock Text="{Binding ModuleStatus}" Foreground="#E5E7EB"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>